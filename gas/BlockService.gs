function getBlockRows_(ss,eventId,blockType){const sh=ss.getSheetByName(SHEET_NAMES.BLOCKS);const values=sh.getDataRange().getValues();const headers=values[0];const rows=[];for(let i=1;i<values.length;i++){const row=rowToObject_(headers,values[i]);if(String(row.isDeleted).toLowerCase()==="true")continue;if(row.eventId!==eventId)continue;if(blockType&&row.blockType!==blockType)continue;rows.push(row);}rows.sort(function(a,b){return Number(a.sortOrder||0)-Number(b.sortOrder||0);});return rows;}
function createBlock_(p){const ss=getSpreadsheet_();const sh=ss.getSheetByName(SHEET_NAMES.BLOCKS);const now=new Date().toISOString();const blockId="BLOCK_"+Utilities.getUuid();const row=[blockId,p.eventId,p.blockType||"memo",p.blockTitle||"無題",p.blockContent||"[]",Number(p.amount||0),p.status||"未設定",p.assignedTo||"",Number(p.sortOrder||999),false,now,now,p.updatedBy||p.lineUserId||"unknown"];sh.appendRow(row);appendHistory_(ss,row[1],blockId,"create","",JSON.stringify(row),row[12]);return{success:true,blockId:blockId};}
function updateBlock_(p){const ss=getSpreadsheet_();const sh=ss.getSheetByName(SHEET_NAMES.BLOCKS);const values=sh.getDataRange().getValues();const headers=values[0];if(!p.blockId)throw new Error("blockId is required.");for(let i=1;i<values.length;i++){const row=rowToObject_(headers,values[i]);if(row.blockId===p.blockId){const before=JSON.stringify(row);const updated=Object.assign(row,{blockType:p.blockType!==undefined?p.blockType:row.blockType,blockTitle:p.blockTitle!==undefined?p.blockTitle:row.blockTitle,blockContent:p.blockContent!==undefined?p.blockContent:row.blockContent,amount:p.amount!==undefined?Number(p.amount):row.amount,status:p.status!==undefined?p.status:row.status,assignedTo:p.assignedTo!==undefined?p.assignedTo:row.assignedTo,sortOrder:p.sortOrder!==undefined?Number(p.sortOrder):row.sortOrder,updatedAt:new Date().toISOString(),updatedBy:p.updatedBy||p.lineUserId||"unknown"});sh.getRange(i+1,1,1,headers.length).setValues([headers.map(function(h){return updated[h];})]);appendHistory_(ss,updated.eventId,p.blockId,"update",before,JSON.stringify(updated),updated.updatedBy);return{success:true,blockId:p.blockId};}}throw new Error("Block not found: "+p.blockId);}
function deleteBlock_(p){const ss=getSpreadsheet_();const sh=ss.getSheetByName(SHEET_NAMES.BLOCKS);const values=sh.getDataRange().getValues();const headers=values[0];if(!p.blockId)throw new Error("blockId is required.");for(let i=1;i<values.length;i++){const row=rowToObject_(headers,values[i]);if(row.blockId===p.blockId){const before=JSON.stringify(row);row.isDeleted=true;row.updatedAt=new Date().toISOString();row.updatedBy=p.updatedBy||p.lineUserId||"unknown";sh.getRange(i+1,1,1,headers.length).setValues([headers.map(function(h){return row[h];})]);appendHistory_(ss,row.eventId,p.blockId,"delete",before,JSON.stringify(row),row.updatedBy);return{success:true,blockId:p.blockId};}}throw new Error("Block not found: "+p.blockId);}
