function getRequestParams_(e){if(!e)return{};const p=e.parameter||{};if(e.postData&&e.postData.contents){try{return Object.assign({},p,JSON.parse(e.postData.contents));}catch(error){return p;}}return p;}function getProperty_(k,f){const v=PropertiesService.getScriptProperties().getProperty(k);return v||f;}function jsonResponse_(d){return ContentService.createTextOutput(JSON.stringify(d)).setMimeType(ContentService.MimeType.JSON);}function rowToObject_(h,r){const o={};h.forEach(function(x,i){o[x]=r[i];});return o;}function appendHistory_(ss,eventId,blockId,action,beforeData,afterData,updatedBy){const sheet=ss.getSheetByName(SHEET_NAMES.HISTORY);sheet.appendRow(['LOG_'+Utilities.getUuid(),eventId,blockId,action,beforeData,afterData,updatedBy,new Date().toISOString()]);}